{
  "id": "nitte-users",
  "realm": "nitte-users",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": true,
  "resetPasswordAllowed": true,
  "bruteForceProtected": true,
  "loginTheme": "nitte",
  "roles": {
    "realm": [
      {
        "name": "platform-admin",
        "description": "[RBAC] Platform administrator with full system access"
      },
      {
        "name": "alumni-verified",
        "description": "[RBAC] Verified alumni with purchasing access"
      },
      {
        "name": "non_alumni",
        "description": "Non-alumni user with limited access"
      },
      {
        "name": "mongo_writer",
        "description": "Internal service role for MongoDB write access"
      }
    ]
  },
  "clients": [
    {
      "clientId": "nitte-client",
      "enabled": true,
      "publicClient": false,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": true,
      "redirectUris": [
        "http://frontend.192.168.56.200.nip.io/*",
        "http://admin.192.168.56.200.nip.io/*"
      ],
      "webOrigins": [
        "http://frontend.192.168.56.200.nip.io",
        "http://admin.192.168.56.200.nip.io"
      ],
      "defaultClientScopes": [
        "openid",
        "profile",
        "email",
        "roles"
      ],
      "protocolMappers": [
        {
          "name": "realm-roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "config": {
            "claim.name": "realm_access.roles",
            "jsonType.label": "String",
            "multivalued": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "client-roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-client-role-mapper",
          "config": {
            "claim.name": "resource_access.${client_id}.roles",
            "jsonType.label": "String",
            "multivalued": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true",
            "usermodel.clientRoleMapping.clientId": "nitte-client"
          }
        }
      ]
    },
    {
      "clientId": "nitte-backend",
      "enabled": true,
      "publicClient": false,
      "serviceAccountsEnabled": true
    }
  ],
  "users": [
    {
      "username": "admin@nitte.edu",
      "email": "admin@nitte.edu",
      "enabled": true,
      "emailVerified": true,
      "realmRoles": [
        "platform-admin"
      ],
      "clientRoles": {
        "nitte-client": [
          "product:create",
          "product:update",
          "product:delete",
          "product:read-all",
          "order:create",
          "order:update",
          "order:read-all",
          "user:manage"
        ]
      }
    },
    {
      "username": "alumni@nitte.edu",
      "email": "alumni@nitte.edu",
      "enabled": true,
      "emailVerified": true,
      "realmRoles": [
        "alumni-verified"
      ],
      "clientRoles": {
        "nitte-client": [
          "order:create",
          "order:update",
          "order:read-own"
        ]
      }
    },
    {
      "username": "guest_user",
      "email": "guest_user@alumni-shop.local",
      "enabled": true,
      "realmRoles": [
        "non_alumni"
      ]
    },
    {
      "username": "service-account-nitte-client",
      "enabled": true,
      "serviceAccountClientId": "nitte-client",
      "realmRoles": [
        "mongo_writer"
      ],
      "clientRoles": {
        "realm-management": [
          "manage-users",
          "view-users",
          "query-users",
          "manage-realm",
          "view-realm"
        ]
      }
    }
  ],
  "eventsListeners": [
    "jboss-logging",
    "nitte-notification-event-listener"
  ]
}