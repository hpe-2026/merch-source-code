{
  "id": "nitte-merchants",
  "realm": "nitte-merchants",
  "displayName": "NITTE Merchants",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "bruteForceProtected": true,
  "loginTheme": "nitte",
  "roles": {
    "realm": [
      {
        "name": "merchant-admin",
        "description": "[RBAC] Merchant administrator - can manage all resources for their merchant"
      },
      {
        "name": "merchant-staff",
        "description": "[RBAC] Merchant staff - limited access to merchant resources"
      }
    ]
  },
  "clients": [
    {
      "clientId": "nitte-client",
      "enabled": true,
      "publicClient": false,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": true,
      "redirectUris": [
        "http://merchant.192.168.56.200.nip.io/*",
        "http://localhost:5175/*"
      ],
      "webOrigins": [
        "http://merchant.192.168.56.200.nip.io"
      ],
      "protocolMappers": [
        {
          "name": "realm-roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "config": {
            "claim.name": "realm_access.roles",
            "jsonType.label": "String",
            "multivalued": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "client-roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-client-role-mapper",
          "config": {
            "claim.name": "resource_access.${client_id}.roles",
            "jsonType.label": "String",
            "multivalued": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true",
            "usermodel.clientRoleMapping.clientId": "nitte-client"
          }
        }
      ],
      "secret": "nitte-client-secret"
    }
  ],
  "users": [
    {
      "username": "merchant-admin@nitte.edu",
      "email": "merchant-admin@nitte.edu",
      "enabled": true,
      "emailVerified": true,
      "realmRoles": [
        "merchant-admin"
      ],
      "attributes": {
        "merchant_id": [
          "nitte-official-store"
        ]
      },
      "clientRoles": {
        "nitte-client": [
          "product:create",
          "product:update",
          "product:delete",
          "order:read-all"
        ]
      },
      "credentials": [
        {
          "type": "password",
          "value": "MerchantAdmin@123",
          "temporary": false
        }
      ]
    },
    {
      "username": "amazon-merchant@amazon.com",
      "email": "amazon-merchant@amazon.com",
      "enabled": true,
      "emailVerified": true,
      "realmRoles": [
        "merchant-admin"
      ],
      "attributes": {
        "merchant_id": [
          "amazon-store"
        ]
      },
      "clientRoles": {
        "nitte-client": [
          "product:create",
          "product:update",
          "product:delete",
          "order:read-all"
        ]
      },
      "credentials": [
        {
          "type": "password",
          "value": "Amazon@123",
          "temporary": false
        }
      ]
    },
    {
      "username": "flipkart-merchant@flipkart.com",
      "email": "flipkart-merchant@flipkart.com",
      "enabled": true,
      "emailVerified": true,
      "realmRoles": [
        "merchant-admin"
      ],
      "attributes": {
        "merchant_id": [
          "flipkart-store"
        ]
      },
      "clientRoles": {
        "nitte-client": [
          "product:create",
          "product:update",
          "product:delete",
          "order:read-all"
        ]
      },
      "credentials": [
        {
          "type": "password",
          "value": "Flipkart@123",
          "temporary": false
        }
      ]
    }
  ],
  "eventsListeners": [
    "jboss-logging",
    "nitte-notification-event-listener"
  ]
}