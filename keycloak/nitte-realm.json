{
  "id": "nitte-realm",
  "realm": "nitte-realm",
  "displayName": "NITTE Alumni Merchandise (Alumni Shop)",
  "enabled": true,
  "loginTheme": "keycloak",
  "sslRequired": "external",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "requiredActions": [
    {
      "alias": "CONFIGURE_TOTP",
      "name": "Configure OTP",
      "providerId": "CONFIGURE_TOTP",
      "enabled": true,
      "defaultAction": false,
      "priority": 10,
      "config": {}
    },
    {
      "alias": "UPDATE_PASSWORD",
      "name": "Update Password",
      "providerId": "UPDATE_PASSWORD",
      "enabled": true,
      "defaultAction": false,
      "priority": 20,
      "config": {}
    }
  ],
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "accessTokenLifespan": 1800,
  "roles": {
    "realm": [
      { "name": "admin",              "description": "System administrator with full access (deprecated - use platform-admin)" },
      { "name": "admin-internal",     "description": "Internal DevOps admin with Jenkins/Nexus/Keycloak Admin access (2FA required)" },
      { "name": "alumni",             "description": "Verified alumni user" },
      { "name": "non_alumni",         "description": "Non-alumni user with limited access" },
      { "name": "merchant",           "description": "Product merchant and seller (deprecated - use merchant-admin or merchant-staff)" },
      { "name": "merchant-amazon",    "description": "Third-party merchant: Amazon" },
      { "name": "merchant-flipkart",  "description": "Third-party merchant: Flipkart" },
      { "name": "internal-user",      "description": "Internal NITTE staff with limited DevOps access (Jenkins viewer, observability read-only)" },
      { "name": "mongo_writer",       "description": "Internal service role allowed to write to MongoDB" },
      { "name": "nexus-admin",        "description": "Nexus repository administrator" },
      { "name": "nexus-developer",    "description": "Nexus repository developer (read/write)" },
      { "name": "keycloak-admin",     "description": "Keycloak administrator with access to audit and security logs" },
      { "name": "platform-admin",     "description": "[RBAC] Platform administrator with full system access" },
      { "name": "merchant-admin",     "description": "[RBAC] Merchant administrator - can manage all resources for their merchant" },
      { "name": "merchant-staff",     "description": "[RBAC] Merchant staff - limited access to merchant resources" },
      { "name": "alumni-verified",    "description": "[RBAC] Verified alumni with purchasing access" }
    ]
  },
  "eventsEnabled": true,
  "eventsExpiration": 86400,
  "eventsListeners": [ "jboss-logging", "nitte-notification-event-listener" ],
  "adminEventsEnabled": true,
  "adminEventsDetailsEnabled": true,
  "clients": [
    {
      "clientId": "nitte-client",
      "name": "NITTE Merchandise Client (alumni-backend)",
      "description": "Confidential backend client for the NITTE / Alumni Shop API",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "nitte-client-secret",
      "redirectUris": ["*"],
      "webOrigins": [
        "http://localhost:5173",
        "http://localhost:5174",
        "http://localhost:3000"
      ],
      "publicClient": false,
      "protocol": "openid-connect",
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": true,
      "authorizationServicesEnabled": false,
      "fullScopeAllowed": true,
      "defaultRoles": ["non_alumni"],
      "protocolMappers": [
        {
          "name": "realm roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "multivalued": "true",
            "userinfo.token.claim": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "realm_access.roles",
            "jsonType.label": "String"
          }
        },
        {
          "name": "client roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-client-role-mapper",
          "consentRequired": false,
          "config": {
            "multivalued": "true",
            "userinfo.token.claim": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "resource_access.${client_id}.roles",
            "jsonType.label": "String"
          }
        },
        {
          "name": "username",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "user.attribute": "username",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "preferred_username",
            "jsonType.label": "String"
          }
        },
        {
          "name": "merchantId attribute",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "user.attribute": "merchantId",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "merchant_id",
            "jsonType.label": "String"
          }
        }
      ]
    },
    {
      "clientId": "nitte-backend",
      "name": "NITTE Backend Service",
      "description": "Internal client for backend-to-backend communication",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "nitte-backend-secret",
      "publicClient": false,
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "authorizationServicesEnabled": false
    },
    {
      "clientId": "jenkins-client",
      "name": "Jenkins CI/CD Server",
      "description": "Client for Jenkins OAuth integration",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "jenkins-client-secret",
      "redirectUris": ["http://localhost:8081/*"],
      "webOrigins": ["http://localhost:8081"],
      "publicClient": false,
      "protocol": "openid-connect",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": true,
      "fullScopeAllowed": true
    },
    {
      "clientId": "observability-proxy",
      "name": "Observability Proxy",
      "description": "oauth2-proxy client for Prometheus and Jaeger",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "observability-proxy-secret",
      "redirectUris": [
        "http://localhost:9090/oauth2/callback",
        "http://localhost:16686/oauth2/callback"
      ],
      "webOrigins": ["http://localhost:9090", "http://localhost:16686"],
      "publicClient": false,
      "protocol": "openid-connect",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "fullScopeAllowed": true
    },
    {
      "clientId": "grafana-client",
      "name": "Grafana Monitoring",
      "description": "Client for Grafana OAuth2 SSO",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "grafana-client-secret",
      "redirectUris": ["http://localhost:3001/*"],
      "webOrigins": ["http://localhost:3001"],
      "publicClient": false,
      "protocol": "openid-connect",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "fullScopeAllowed": true
    },
    {
      "clientId": "nexus-client",
      "name": "Sonatype Nexus Repository",
      "description": "Client for Nexus OAuth integration",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "nexus-client-secret",
      "redirectUris": ["http://localhost:8082/*"],
      "webOrigins": ["http://localhost:8082"],
      "publicClient": false,
      "protocol": "openid-connect",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": true,
      "fullScopeAllowed": true
    },
    {
      "clientId": "minio-client",
      "name": "MinIO Object Storage",
      "description": "Client for MinIO OIDC login",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "minio-client-secret",
      "redirectUris": ["http://localhost:9001/oauth_callback"],
      "webOrigins": ["http://localhost:9001"],
      "publicClient": false,
      "protocol": "openid-connect",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "fullScopeAllowed": true,
      "protocolMappers": [
        {
          "name": "minio-policy-mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-hardcoded-claim-mapper",
          "consentRequired": false,
          "config": {
            "claim.name": "policy",
            "claim.value": "consoleAdmin",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "admin@nitte.edu",
      "enabled": true,
      "email": "admin@nitte.edu",
      "emailVerified": true,
      "firstName": "Admin",
      "lastName": "User",
      "credentials": [{ "type": "password", "value": "admin@123",    "temporary": false }],
      "realmRoles": ["platform-admin"],
      "clientRoles": {
        "nitte-client": [
          "product:create",
          "product:update",
          "product:delete",
          "product:read-all",
          "order:create",
          "order:update",
          "order:read-all",
          "user:manage"
        ]
      }
    },
    {
      "username": "alumni@nitte.edu",
      "enabled": true,
      "email": "alumni@nitte.edu",
      "emailVerified": true,
      "firstName": "Alumni",
      "lastName": "User",
      "credentials": [{ "type": "password", "value": "alumni@123",   "temporary": false }],
      "realmRoles": ["alumni-verified"],
      "clientRoles": {
        "nitte-client": [
          "order:create",
          "order:update",
          "order:read-own"
        ]
      }
    },
    {
      "username": "guest_user",
      "enabled": true,
      "email": "guest_user@alumni-shop.local",
      "emailVerified": true,
      "firstName": "Guest",
      "lastName": "Demo",
      "credentials": [{ "type": "password", "value": "Guest@123",    "temporary": false }],
      "realmRoles": ["non_alumni"]
    },
    {
      "username": "service-account-nitte-client",
      "enabled": true,
      "serviceAccountClientId": "nitte-client",
      "realmRoles": ["mongo_writer"],
      "clientRoles": {
        "realm-management": [
          "manage-users",
          "view-users",
          "query-users",
          "manage-realm",
          "view-realm"
        ]
      }
    },
    {
      "username": "service-account-nexus-client",
      "enabled": true,
      "serviceAccountClientId": "nexus-client",
      "clientRoles": {
        "realm-management": [
          "view-realm",
          "view-clients",
          "view-users"
        ]
      }
    },
    {
      "username": "internal-admin@nitte.ac.in",
      "enabled": true,
      "email": "internal-admin@nitte.ac.in",
      "emailVerified": true,
      "firstName": "Internal",
      "lastName": "Admin",
      "credentials": [{ "type": "password", "value": "InternalAdmin@123", "temporary": false }],
      "realmRoles": ["admin-internal", "nexus-admin", "keycloak-admin"],
      "requiredActions": ["CONFIGURE_TOTP"]
    },
    {
      "username": "internal-user@nitte.ac.in",
      "enabled": true,
      "email": "internal-user@nitte.ac.in",
      "emailVerified": true,
      "firstName": "Internal",
      "lastName": "User",
      "credentials": [{ "type": "password", "value": "InternalUser@123", "temporary": false }],
      "realmRoles": ["internal-user", "nexus-developer"]
    },
    {
      "username": "amazon-merchant@amazon.com",
      "enabled": true,
      "email": "amazon-merchant@amazon.com",
      "emailVerified": true,
      "firstName": "Amazon",
      "lastName": "Merchant",
      "credentials": [{ "type": "password", "value": "Amazon@123", "temporary": false }],
      "realmRoles": ["merchant-admin"],
      "attributes": {
        "merchantId": ["amazon-store"]
      },
      "clientRoles": {
        "nitte-client": [
          "product:create",
          "product:update",
          "product:delete",
          "order:read-all"
        ]
      }
    },
    {
      "username": "flipkart-merchant@flipkart.com",
      "enabled": true,
      "email": "flipkart-merchant@flipkart.com",
      "emailVerified": true,
      "firstName": "Flipkart",
      "lastName": "Merchant",
      "credentials": [{ "type": "password", "value": "Flipkart@123", "temporary": false }],
      "realmRoles": ["merchant-admin"],
      "attributes": {
        "merchantId": ["flipkart-store"]
      },
      "clientRoles": {
        "nitte-client": [
          "product:create",
          "product:update",
          "product:delete",
          "order:read-all"
        ]
      }
    },
    {
      "username": "merchant-admin@nitte.edu",
      "enabled": true,
      "email": "merchant-admin@nitte.edu",
      "emailVerified": true,
      "firstName": "Merchant",
      "lastName": "Admin",
      "credentials": [{ "type": "password", "value": "MerchantAdmin@123", "temporary": false }],
      "realmRoles": ["merchant-admin"],
      "attributes": {
        "merchantId": ["nitte-official-store"]
      },
      "clientRoles": {
        "nitte-client": [
          "product:create",
          "product:update",
          "product:delete",
          "order:read-all"
        ]
      }
    }
  ]
}
