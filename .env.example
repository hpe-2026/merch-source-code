# =============================================================================
# NITTE Merchandise Shop — Root .env for docker-compose
# =============================================================================
#
# USAGE:
#   cp .env.example .env
#   # Edit .env and fill in the REQUIRED values marked below.
#   docker compose up --build
#
# This file is read by docker-compose.yml for the infrastructure layer.
# Each service also reads its own service-level .env from its directory,
# but for local development docker-compose injects env vars directly
# so service-level .env files are only needed when running services standalone.
#
# NEVER commit .env to git. .env.example is safe to commit.
# =============================================================================

# ─── REQUIRED — application will refuse to start without these ───────────────

# JWT signing secret for node-backend (HS256 tokens for MongoDB-based auth).
# Must be a long random string. Generate one with:
#   openssl rand -hex 32
JWT_SECRET=CHANGE_THIS_generate_with_openssl_rand_hex_32

# Keycloak OIDC client secret.
# Get this from the Keycloak Admin UI after creating the nitte-client:
#   Realm → Clients → nitte-client → Credentials → Client Secret
KEYCLOAK_CLIENT_SECRET=CHANGE_THIS_get_from_keycloak_admin_ui

# ─── RECOMMENDED — insecure defaults used if not set ─────────────────────────

# MongoDB root password (used by all services connecting to MongoDB)
MONGODB_ROOT_PASSWORD=change-this-mongo-root-password

# Keycloak admin console password (http://localhost:8080 → admin / this password)
KEYCLOAK_ADMIN_PASSWORD=admin_password

# MinIO root password (MinIO console: http://localhost:9001 → minioadmin / this)
MINIO_ROOT_PASSWORD=change-this-minio-secret
