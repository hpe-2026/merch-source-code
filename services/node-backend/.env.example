NODE_ENV=development
PORT=3000

# Database — must match python-service DATABASE_NAME (nitte_merch)
MONGODB_URL=mongodb://localhost:27017/nitte_merch

# JWT — REQUIRED. Application will refuse to start if not set.
JWT_SECRET=change-this-to-a-random-64-char-string-in-all-environments
JWT_EXPIRY=7d

# Python service
PYTHON_SERVICE_URL=http://localhost:8000

# Logging
LOG_LEVEL=info
REQUEST_TIMEOUT=30000

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175

# Keycloak — KEYCLOAK_CLIENT_SECRET is REQUIRED. Application will refuse to start if not set.
KEYCLOAK_SERVER_URL=http://localhost:8080
KEYCLOAK_REALM=nitte-realm
KEYCLOAK_CLIENT_ID=nitte-client
KEYCLOAK_CLIENT_SECRET=change-this-to-your-keycloak-client-secret

# Kafka
KAFKA_BROKERS=localhost:9092

# Jaeger (OpenTelemetry)
JAEGER_HOST=jaeger
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# MinIO / S3
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=change-this-minio-secret
S3_BUCKET_NAME=nitte-users
S3_PRODUCTS_BUCKET=nitte-products

# Payments (optional)
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
