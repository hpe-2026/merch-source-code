ENVIRONMENT=development
PORT=8000
HOST=0.0.0.0

# Database — must match node-backend's MONGODB_URL database name (nitte_merch)
MONGODB_URL=mongodb://localhost:27017
DATABASE_NAME=nitte_merch

LOG_LEVEL=info
API_GATEWAY_URL=http://localhost:3000

# Jaeger tracing — hostname must match docker-compose service name
JAEGER_AGENT_HOST=jaeger
JAEGER_AGENT_PORT=6831
